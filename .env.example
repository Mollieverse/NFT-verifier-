# ─── Required ────────────────────────────────────────────────────────────────
# Postgres connection string. Use the POOLED endpoint for serverless (Vercel).
#   Neon:     ?sslmode=require&channel_binding=require   (use the "Pooled" URL)
#   Supabase: use the "Transaction" pooler URL on port 6543
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Helius RPC key — required for all Solana lookups. Free tier at helius.dev.
HELIUS_API_KEY=""

# Public base URL of the deployed site (no trailing slash). Used in metadata.
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── Optional ────────────────────────────────────────────────────────────────
# Reservoir API key — raises EVM rate limits (free tier works keyless, but
# production traffic will hit limits quickly). Get one at reservoir.tools.
RESERVOIR_API_KEY=""
