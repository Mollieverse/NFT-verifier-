{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/verify/image/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/verify/address/route.ts": {
      "maxDuration": 20
    },
    "src/app/api/verify/wallet/route.ts": {
      "maxDuration": 30
    }
  }
}
